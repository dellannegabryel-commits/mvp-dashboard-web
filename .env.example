# API base URL (em produção). No dev com MSW, deixe vazio para usar os mocks.
NEXT_PUBLIC_API_BASE_URL=

# Habilitar MSW no client (true para dev, false/remover para prod)
NEXT_PUBLIC_USE_MSW=true

# Bypass auth check no dev (true = pula login, false/remover = auth ativo)
NEXT_PUBLIC_BYPASS_AUTH=true

# next-auth (Auth.js v5)
# Em dev pode-se usar um valor dummy; em prod, gere com `openssl rand -base64 32`.
AUTH_SECRET=dev-only-do-not-use-in-prod
AUTH_TRUST_HOST=true

# Ambiente
NODE_ENV=development
