# API base URL (em produção). No dev com MSW, deixe vazio para usar os mocks.
NEXT_PUBLIC_API_BASE_URL=

# next-auth (Auth.js v5)
# Em dev pode-se usar um valor dummy; em prod, gere com `openssl rand -base64 32`.
AUTH_SECRET=dev-only-do-not-use-in-prod
AUTH_TRUST_HOST=true

# Ambiente
NODE_ENV=development
